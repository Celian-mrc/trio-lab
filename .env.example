# Copier vers .env et remplir — .env n'est JAMAIS committé.

# Clé API Riot (https://developer.riotgames.com)
RIOT_API_KEY=

# Postgres (Railway en prod, local en dev)
DATABASE_URL=postgresql://user:password@localhost:5432/triolab

# Postgres de test pour les tests d'intégration storage (optionnel : sautés si
# absent). Utiliser une base JETABLE — les tests tronquent les tables.
TEST_DATABASE_URL=

# Identifiants du dashboard /admin (HTTP Basic Auth).
ADMIN_USER=
ADMIN_PASSWORD=

# Dossier des données locales (archives timeline JSON.gz, jamais en base).
DATA_DIR=./data

LOG_LEVEL=INFO
